alias e=exit
alias gcc='gcc -std=c23 -fsanitize=address'
alias v=~/Applications/nvim-linux-x86_64.appimage
alias c=clear
alias t='tput reset'
alias update='sudo apt update -y && sudo apt full-upgrade -y'
alias l="ls -1 && echo 'Total files: $(ls -1 | wc -l)'"
alias ls="ls -1 && echo 'Total files: $(ls -1 | wc -l)'"
