#alias ls='ls -X -1 --group-directories-first --color=auto'
alias py=python
alias acpi="echo 'Advanced Configuration and Power Interface)cienntly, particularly for power management, device' && acpi"
alias lsblk="echo 'list block device' && lsblk"
